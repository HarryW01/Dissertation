    doi = {10.1137/0201010},
    abstract = {The value of depth-first search or “backtracking” as a technique for solving problems is illustrated by two examples. An improved version of an algorithm for finding the strongly connected components of a directed graph and at algorithm for finding the biconnected components of an undirect graph are presented. The space and time requirements of both algorithms are bounded by {\textbackslash}k\_1 V + k\_2 E + k\_3 {\textbackslash} for some constants {\textbackslash}k\_1 ,k\_2 {\textbackslash}, and {\textbackslash}k\_3 {\textbackslash}, where V is the number of vertices and E is the number of edges of the graph being examined.},
    number = {2},
